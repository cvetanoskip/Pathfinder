{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "downlevelIteration": true,
    "lib": [
      "ES2017",
      "DOM"
    ],
    "types": [
      "jest",
      "@testing-library/react-native"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "__tests__/**/*.ts",
    "__tests__/**/*.tsx",
    "nativewind-env.d.ts"
  ]
}